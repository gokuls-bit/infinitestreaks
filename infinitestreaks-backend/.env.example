# Environment Variables Example for InfiniteStreaks Backend

# Server Port
PORT=5000

# Environment: development, production, test
NODE_ENV=development

# MongoDB Connection String (Atlas or Local)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/infinitestreaks?retryWrites=true&w=majority

# JWT Secrets and Expiration
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Rate Limiting
# MAX_REQUESTS_PER_15_MIN=100
